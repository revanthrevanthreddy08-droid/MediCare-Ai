# Use high-entropy random keys generated cryptographically in production.
# Never expose this configuration or commit real passwords/secrets to Git.

# Flask Application Settings
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_APP=app.py
PORT=5000

# High-Entropy Cryptographic Secrets
# Generated using: openssl rand -hex 32
JWT_SECRET_KEY=9a3f2dbe10f0f354f9c5d0da4abfb1a2d1ca6f6be9636ef47e6ff8129e1fa20f
REFRESH_TOKEN_SECRET=bf3db77c38c03563459c5d1aa4abfb2a2d2ca6f6be9636ef47e6ff8129e1fa55e
FLASK_COOKIE_SECRET=eed1f8ebc8a00563459c5d2aa4abfb3a2d3ca6f6be9636ef47e6ff8129e1ff2a1
AES_ENCRYPTION_KEY=3dbf77c38c12563459c5d1aa4abfb4a2d4ca6f6be9636ef47e6ff8129e1fa88c  # AES-256 Key in Hex

# Database Security (MySQL Production Settings, fallbacks to secure SQLite)
DATABASE_TYPE=mysql+pymysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=medicare_ai_prod
DATABASE_USER=medicare_secure_app
DATABASE_PASSWORD=SuperSecureComplexHashedDbPassword_2026_@Admin!

# Security Header & Session Settings
SECURE_COOKIE_HTTPONLY=True
SECURE_COOKIE_SAMESITE=Strict
SECURE_COOKIE_SECURE=True
SESSION_INACTIVITY_LIMIT_MINUTES=15

# Security Access Rate-Limiter (Requests per window duration)
MAX_LOGIN_ATTEMPTS_PER_IP=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_GLOBAL=100/minute

# Secure File Upload Controls
MAX_CONTENT_LENGTH_MB=16
ALLOWED_EXTENSIONS=pdf,jpg,png
UPLOAD_STORE_DIRECTORY=/var/medicare/secure_uploads

# Multi-Factor Authentication
MFA_ISSUER=MediCareAI
MFA_FORCE_ENROLL=False
